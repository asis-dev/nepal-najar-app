{
  "crons": [
    {
      "path": "/api/intelligence/sweep?secret=${CRON_SECRET}",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/intelligence/sweep?secret=${CRON_SECRET}&mode=rss-only",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/intelligence/worker?secret=${CRON_SECRET}&limit=10",
      "schedule": "*/15 * * * *"
    }
  ]
}
