NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=Nepal Najar

# Supabase public read access (optional for build, required for live data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase server/admin access
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Scrape API auth
SCRAPE_SECRET=your-scrape-secret
CRON_SECRET=your-cron-secret
SERVICE_OPS_WORKER_SECRET=your-service-ops-worker-secret

# Admin dashboard access
ADMIN_SECRET=your-admin-password
OWNER_EMAIL=founder@example.com
# or use OWNER_USER_ID / OWNER_USER_IDS once the owner account exists

# Ops alerting
OPS_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook

# AI Analysis (optional — falls back to keyword matching)
AI_BASE_URL=http://localhost:1234/v1
AI_API_KEY=lm-studio
AI_MODEL=qwen3.5-27b
