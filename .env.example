# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nepal_progress
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/nepal_progress_test

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── JWT ──
JWT_SECRET=change-me-in-production-use-64-char-random-string
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800
OTP_EXPIRY_MINUTES=5

# ── S3 / MinIO ──
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=nepal-progress-evidence
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ── App ──
NODE_ENV=development
PORT=3001
ADMIN_WEB_URL=http://localhost:3000

# ── Admin / Scraper Auth ──
# Secret used by automation callers for scrape/sweep endpoints.
SCRAPE_SECRET=change-me
# For dashboard cookie-session auth on scrape endpoints, enforce same-origin checks.
# Set to false only if you run trusted non-browser callers with admin cookies.
ENFORCE_SCRAPE_ORIGIN_CHECK=true
# Keep false unless you intentionally need legacy ADMIN_SECRET cookie auth.
ENABLE_LEGACY_ADMIN_SECRET=false
# Legacy fallback only (optional, avoid using in production).
ADMIN_SECRET=
# Optional owner lock for dashboard/admin APIs. Set at least one.
# You can use email if you don't want to look up UUIDs in Supabase.
OWNER_EMAIL=
OWNER_USER_ID=
# Comma-separated variants if needed for temporary multi-owner operation.
OWNER_EMAILS=
OWNER_USER_IDS=
# Keep false to prevent new verifier/admin promotions from the app.
ADMIN_ROLE_PROMOTION_ENABLED=false
# Default user hierarchy is 2-level (citizen/admin). Set true to expose observer/verifier roles.
NEXT_PUBLIC_ENABLE_EXTENDED_ROLES=false

# ── Distributed Rate Limit (optional, recommended for serverless) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Intelligence Routing ──
# Force OpenClaw-only inference path for non-transcription tasks.
INTELLIGENCE_OPENCLAW_ONLY=true
# Prefer OpenClaw first (falls back to other providers if unavailable).
INTELLIGENCE_PREFER_OPENCLAW=true
# Emergency kill-switch for OpenClaw in production.
OPENCLAW_DISABLED=false

# ── Intelligence Throughput / Safety ──
# Analysis lookback horizon in hours. Set 0 for unlimited backlog sweep.
INTELLIGENCE_ANALYSIS_LOOKBACK_HOURS=168
# Keep false in production for human-reviewed status publishing.
INTELLIGENCE_ALLOW_DIRECT_STATUS_WRITES=false
# Second-AI verifier autopilot for status recommendations (set once, not per run).
INTELLIGENCE_STATUS_AUTOPILOT_ENABLED=true
# Safer launch default: review suggestions automatically, apply only when explicitly enabled.
INTELLIGENCE_STATUS_AUTOPILOT_AUTO_APPLY=false
INTELLIGENCE_STATUS_AUTOPILOT_MIN_SIGNALS=5
INTELLIGENCE_STATUS_AUTOPILOT_MIN_UNIQUE_SOURCES=2
INTELLIGENCE_STATUS_AUTOPILOT_MIN_CONFIDENCE=0.75
# Daily brief media knobs
BRIEF_MAX_SECONDS=30
BRIEF_VIDEO_ENABLED=true
BRIEF_VIDEO_MAX_SECONDS=30
# Reuse same-day generated video to reduce cost/latency on repeated runs.
BRIEF_VIDEO_REUSE_EXISTING=true
# Keep true to enforce Sagar for video narration (skip video if Sagar unavailable).
BRIEF_VIDEO_REQUIRE_SAGAR=true
# D-ID video generation (required only for animated brief video)
DID_API_KEY=
# Optional: set presenter/avatar explicitly (recommended: pick a male presenter for Sagar voice match).
# If unset, app uses internal defaults.
DID_PRESENTER_ID=
DID_AVATAR_URL=
# Optional text-mode voice fallback (audio-mode uses uploaded narration file)
DID_VOICE_ID=ne-NP-SagarNeural
# Optional ops alert webhook (Slack/Discord/custom) for sweep/worker failures.
INTELLIGENCE_ALERT_WEBHOOK_URL=
OPS_ALERT_WEBHOOK_URL=

# ── AI Service (Phase 3) ──
# AI_SERVICE_URL=http://localhost:8000
# ANTHROPIC_API_KEY=sk-ant-...
