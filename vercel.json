{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "ignoreCommand": "exit 1",
  "crons": [
    {
      "path": "/api/intelligence/sweep?mode=full",
      "schedule": "15 1,13,19 * * *"
    },
    {
      "path": "/api/intelligence/worker?limit=10&batchSize=10&translationBatchSize=20",
      "schedule": "30 1,13,19 * * *"
    },
    {
      "path": "/api/ministers/refresh",
      "schedule": "15 13 * * *"
    },
    {
      "path": "/api/daily-brief?generate=1&noaudio=1",
      "schedule": "45 1,13 * * *"
    },
    {
      "path": "/api/daily-brief?audioonly=1",
      "schedule": "0 2,14 * * *"
    },
    {
      "path": "/api/daily-brief?videoonly=1",
      "schedule": "10 2,14 * * *"
    },
    {
      "path": "/api/vault/reminders/tick",
      "schedule": "0 3 * * *"
    }
  ]
}
