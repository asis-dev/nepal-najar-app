{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "ignoreCommand": "exit 1",
  "crons": [
    {
      "path": "/api/intelligence/sweep?mode=full",
      "schedule": "15 1,13 * * *"
    },
    {
      "path": "/api/intelligence/worker?limit=10",
      "schedule": "30 1,13 * * *"
    },
    {
      "path": "/api/ministers/refresh",
      "schedule": "15 13 * * *"
    }
  ]
}
